rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null &&
        firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid)) &&
        firestore.get(/databases/(default)/documents/admins/$(request.auth.uid)).data.role == "admin";
    }

    // Imágenes subidas desde el panel /admin (secciones, fotos del sitio).
    match /media/{fileName} {
      allow read: if true;                 // públicas, se muestran en la landing
      allow write: if isAdmin()
        && request.resource.size < 8 * 1024 * 1024   // máx. 8MB
        && request.resource.contentType.matches('image/.*');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
